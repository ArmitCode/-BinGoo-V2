# Safe temp file creation function
safe_mktemp() {
    local prefix="$1"
    local tmpfile
    # Try mktemp first
    tmpfile=$(mktemp "${JUNK}/${prefix}.XXXXXX" 2>/dev/null)
    if [ -z "$tmpfile" ] || [ ! -f "$tmpfile" ]; then
        # Fallback: create manually
        tmpfile="${JUNK}/${prefix}.$$.$RANDOM"
        touch "$tmpfile" 2>/dev/null || tmpfile="./${prefix}.$$.$RANDOM"
        touch "$tmpfile" 2>/dev/null
    fi
    echo "$tmpfile"
}

