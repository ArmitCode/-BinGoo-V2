		grep -i "$CHKREG" "$CHK2" 2> /dev/null 2>&1
		if [ "$?" == 0 ]; then
		#Add to Case statement if you add new LFI regex to the regex array to help sort results better :)
			case "$CHKREG" in
				"Warning: include(")
					lfi_reg
				;;
				"Warning: require_once(")
					lfi_reg
				;;
				"function.include")
					lfi_reg
				;;
				"Disallowed Parent Path")
					lfi_reg
				;;
				"include_path")
					lfi_reg
				;;
				"function.require")
					lfi_reg
				;;
				"Warning: main(")
					lfi_reg
				;;
				"Warning: file_get_contents(")
					lfi_reg
				;;
				"Warning: fopen(")
					lfi_reg
				;;
				"Warning: readfile(")
					lfi_reg
				;;
				"failed to open stream")
					lfi_reg
				;;
				"No such file or directory")
					lfi_reg
				;;
				*)
					sqli_reg
				;;
			esac
		else
			FAIL=0
		fi
		z=$(( z +1 ))
		i=$(( i +1 ))
	done
	if [ "$FAIL" == 0 ]; then
		statistic_count			
	fi
	if [ "$FAIL" == 0 ]; then
		echo "Nothing Found: $sitetargets"			
	fi
	cat "$STORAGE3" | uniq >> "$STORAGE5" 2> /dev/null 2>&1
}

# Break out the curl magic so we can call this function and launch in background to help speed things up when we have large list files
curl_magic(){
	cat "$lnkfile" | while read sitetargets
	do
		sitetargets2=$(echo "$sitetargets" | sed 's/$/%27/');
		UA=$(shuf -e "$uagent1" "$uagent2" "$uagent3" "$uagent4" -n 1)
		curl "$sitetargets" --retry 1 --retry-delay 3 --connect-timeout 2 --no-keepalive -s -e "http://www.google.com/q?=foobar" -A "$UA" -o "$CHK1"
		curl "$sitetargets2" --retry 1 --retry-delay 3 --connect-timeout 2 --no-keepalive -s -e "http://www.google.com/q?=foobar" -A "$UA" -o "$CHK2"
		regex_check 2> /dev/null
	done
}

