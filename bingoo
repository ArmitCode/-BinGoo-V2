# Google Search - Updated to use curl instead of lynx
g_finder(){
# We use CURL to query Google search engine. From tests the page count changes by 10 each time you change pages so we make a nice while loop so that while less than 250 continue checking for links.
# Added random delays and UA rotation to avoid blocks.
	local page=0
	while [ "$COUNT" -le 250 ];
	do
		# Rotate user agents to avoid detection
		UA=$(shuf -e "$uagent1" "$uagent2" "$uagent3" "$uagent4" -n 1)
		# Use curl with proper headers to mimic browser
		curl -s -L \
			-H "User-Agent: $UA" \
			-H "Accept: text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8" \
			-H "Accept-Language: en-US,en;q=0.5" \
			-H "Accept-Encoding: gzip, deflate, br" \
			-H "DNT: 1" \
			-H "Connection: keep-alive" \
			-H "Upgrade-Insecure-Requests: 1" \
			--compressed \
			--connect-timeout 10 \
			--max-time 30 \
			"https://www.google.com/search?q=$1&start=$COUNT" 2>/dev/null | \
			grep -o 'href="[^"]*url?q=[^"]*"' | \
			sed 's/href="//;s/"$//' | \
			sed 's/.*url?q=//' | \
			sed 's/&amp;/\&/g' | \
			sed 's/&sa=.*//' | \
			grep -v '^http://www.google.com' | \
			grep -v '^/search' >> "$STORAGE1"

		COUNT=$(( $COUNT + 10 ))
		page=$(( $page + 1 ))
		# Random delay between requests to avoid rate limiting
		sleep $(awk -v min=1 -v max=3 'BEGIN{srand(); print min+rand()*(max-min)}')
	done
	echo
}

